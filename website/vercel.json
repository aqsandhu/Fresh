{
  "version": 2,
  "buildCommand": "cd .. && pnpm turbo run build --filter=freshbazar-website",
  "framework": "nextjs",
  "installCommand": "cd .. && pnpm install --frozen-lockfile",
  "env": {
    "NEXT_PUBLIC_API_URL": "https://freshbazar-backend.onrender.com/api",
    "NEXT_PUBLIC_APP_NAME": "Fresh Bazar"
  },
  "rewrites": [
    {
      "source": "/api/:path((?!auth/).*)",
      "destination": "https://freshbazar-backend.onrender.com/api/:path"
    }
  ]
}
