# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this to .env and fill in the values before deploying
# =============================================================================

# Server Configuration
NODE_ENV=production
PORT=3000

# Database Configuration
DB_HOST=your-db-host.com
DB_PORT=5432
DB_NAME=grocery_db
DB_USER=your_db_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_SSL=true
DB_POOL_MIN=5
DB_POOL_MAX=20

# JWT Configuration - GENERATE STRONG RANDOM SECRETS!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_64_CHAR_RANDOM_SECRET
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_64_CHAR_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# CORS — every browser front-end that calls this API (comma-separated, no trailing slash)
CORS_ORIGIN=https://freshbazar.pk,https://www.freshbazar.pk,https://freshbazar-admin.vercel.app,https://admin.freshbazar.pk
CORS_EXTRA_ORIGINS=
CORS_CREDENTIALS=true

# HttpOnly-cookie auth for the ADMIN PANEL (XSS hardening — tokens never
# reach JS). Pair with VITE_AUTH_COOKIES=true on the admin panel build.
# Cross-site deployments (panel + API on different registrable domains)
# additionally need AUTH_COOKIE_SAMESITE=none; same-site subdomain setups
# (admin.freshbazar.pk -> api.freshbazar.pk) should instead share the cookie
# via AUTH_COOKIE_DOMAIN=.freshbazar.pk and keep SameSite=lax.
ADMIN_AUTH_COOKIES=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# HMAC secret for incoming webhooks (x-webhook-signature, SHA-256 over the
# RAW request body). Webhooks are rejected when unset.
WEBHOOK_SECRET=GENERATE_A_64_CHAR_RANDOM_SECRET

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Delivery Configuration
DEFAULT_DELIVERY_CHARGE=100
FREE_DELIVERY_MIN_AMOUNT=500

# Logging
LOG_LEVEL=info
