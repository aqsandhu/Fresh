# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this to .env and fill in the values before deploying
# =============================================================================

# Server Configuration
NODE_ENV=production
PORT=3000

# Database Configuration
DB_HOST=your-db-host.com
DB_PORT=5432
DB_NAME=grocery_db
DB_USER=your_db_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_SSL=true
DB_POOL_MIN=5
DB_POOL_MAX=20

# JWT Configuration - GENERATE STRONG RANDOM SECRETS!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_64_CHAR_RANDOM_SECRET
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_64_CHAR_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# CORS Configuration - Set to your actual production domains
CORS_ORIGIN=https://your-website.com,https://admin.your-website.com
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Delivery Configuration
DEFAULT_DELIVERY_CHARGE=100
FREE_DELIVERY_MIN_AMOUNT=500

# Logging
LOG_LEVEL=info
