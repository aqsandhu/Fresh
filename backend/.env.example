# Fresh Bazar Backend Environment Variables
# Copy this to .env and fill in your values

# Database (Supabase PostgreSQL)
DB_HOST=your-project.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=postgres
DB_SSL=true
# TLS certificate verification (recommended in production):
#   DB_SSL_CA = provider CA cert, PEM or base64 (Supabase: Settings → Database → SSL Certificate)
#   or DB_SSL_REJECT_UNAUTHORIZED=true to verify against system CAs.
# Without either, the connection is encrypted but UNVERIFIED (MITM-open).
# DB_SSL_CA=
# DB_SSL_REJECT_UNAUTHORIZED=true

# Full connection string (alternative)
# DATABASE_URL=postgresql://postgres:PASSWORD@db.your-project.supabase.co:5432/postgres

# JWT (Generate strong secrets at https://generate-secret.vercel.app/)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://freshbazar.vercel.app,https://freshbazar-admin.netlify.app
CORS_EXTRA_ORIGINS=
CORS_CREDENTIALS=true

# Redis (optional — enables distributed rate limiting across instances)
REDIS_URL=redis://localhost:6379

# Legacy password register (disabled by default — use OTP verify-register)
LEGACY_PASSWORD_REGISTER=false

# Sentry
SENTRY_DSN=

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── OTP provider ──────────────────────────────────────────────────────────
# OTP_PROVIDER=backend  → backend generates + sends codes itself
#   (WhatsApp Cloud API first, SMS gateway fallback — much cheaper than
#   Firebase in Pakistan). Leave unset for Firebase idToken flow.
#   OTP_BYPASS_ENABLED=true overrides everything (fixed code, no SMS).
# OTP_PROVIDER=backend
# OTP_TTL_SECONDS=300
# OTP_RESEND_COOLDOWN_SECONDS=45
# OTP_MAX_ATTEMPTS=5
# OTP_MAX_SENDS_PER_PHONE_HOUR=5
# OTP_MAX_SENDS_PER_IP_HOUR=15

# WhatsApp Cloud API (Meta) — authentication template with one-tap button
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_OTP_TEMPLATE=otp_code
# WHATSAPP_OTP_LANGUAGE=en
# WHATSAPP_API_VERSION=v21.0

# SMS gateway (Pakistani providers) — SMS_PROVIDER=sendpk | veevotech | custom
# SMS_PROVIDER=sendpk
# SMS_SENDER_ID=FreshBazar          (PTA-registered mask)
# SMS_BRAND_NAME=Fresh Bazar        (shown inside the OTP text)
# SMS_APP_HASH=                     (11-char Android app hash → zero-tap auto-read)
# SMS_SUCCESS_MATCH=OK              (substring the gateway returns on success)
#   sendpk:    SMS_USERNAME= SMS_PASSWORD=
#   veevotech: SMS_API_KEY=
#   custom:    SMS_API_URL=https://gateway.example/send?to={phone}&text={message}

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Server
NODE_ENV=production
PORT=3000

# API Docs (Swagger)
# SWAGGER_PASSWORD=your_secret_here  (production only — sent via x-swagger-password header)
