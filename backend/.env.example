# Fresh Bazar Backend Environment Variables
# Copy this to .env and fill in your values

# Database (Supabase PostgreSQL)
DB_HOST=db.kvyjqqtkpozxpvuoalyw.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Aq@146776786
DB_NAME=postgres
DB_SSL=true

# Full connection string (alternative)
# DATABASE_URL=postgresql://postgres:Aq%40146776786@db.kvyjqqtkpozxpvuoalyw.supabase.co:5432/postgres

# JWT (Generate strong secrets at https://generate-secret.vercel.app/)
