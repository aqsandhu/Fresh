# Copy to .env and restart Expo (pnpm start)
# Same backend as website (Vercel) + admin panel — Supabase is behind this API on Render.

EXPO_PUBLIC_API_URL=https://freshbazar-backend.onrender.com/api

# Google Maps — required for map tiles on Android (use same key as website)
# Enable: Maps SDK for Android, Maps SDK for iOS (optional), Maps JavaScript API
# Restrict Android key to package com.freshbazar.customer + your SHA-1 (expo run:android / EAS)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: only if Render has OTP_BYPASS_ENABLED=true (testing without SMS)
EXPO_PUBLIC_OTP_BYPASS=false
EXPO_PUBLIC_OTP_BYPASS_CODE=123789
