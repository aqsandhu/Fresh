{
  "name": "@freshbazar/monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.3",
  "description": "FreshBazar — Pakistani Grocery Delivery Platform (Monorepo)",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "clean": "turbo run clean && node -e \"require('fs').rmSync('node_modules/.cache',{recursive:true,force:true})\"",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "~19.1.10",
      "freshbazar-website>@types/react": "18.3.29",
      "freshbazar-admin>@types/react": "18.3.29",
      "@react-navigation/native>@types/react": "~19.1.10",
      "@react-navigation/bottom-tabs>@types/react": "~19.1.10",
      "@react-navigation/native-stack>@types/react": "~19.1.10",
      "@react-navigation/core>@types/react": "~19.1.10",
      "@react-navigation/elements>@types/react": "~19.1.10",
      "@react-navigation/routers>@types/react": "~19.1.10"
    }
  }
}
