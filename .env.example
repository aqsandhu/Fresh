# ============================================================================
# FreshBazar Environment Variables
# Copy this file to .env and fill in all required values
# ============================================================================

# ── Database ──────────────────────────────────────────────────────────────
# Preferred in production: a single connection string. When set, the pool auto-
# detects Supabase pooler mode (:6543 / pgbouncer=true) and sizes itself. The
# discrete DB_* vars below are the fallback for local/dev.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=          # REQUIRED: Set a strong database password
DB_NAME=freshbazar
DB_SSL=false
# Optional: PEM of a CA cert to VERIFY the DB TLS chain (pins the self-signed
# Supabase chain). Leave unset to keep rejectUnauthorized:false.
DB_SSL_CA=
# Optional: direct Postgres URL for DDL migrations when DATABASE_URL uses Supabase pooler (:6543)
DATABASE_MIGRATION_URL=

# ── Object Storage (Supabase Storage) ────────────────────────────────────
# REQUIRED in production for file uploads to PERSIST. Without these the upload
# middleware logs an error and the file is silently dropped (row saved with no
# image_url). See backend/src/config/storage.ts.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin bootstrap (optional, idempotent on every boot) ─────────────────
# When BOTH are set, the API upserts a super_admin with this phone/password on
# startup. Leave unset once the admin account exists. See scripts/bootstrapAdmin.ts.
ADMIN_PHONE=
ADMIN_PASSWORD=

# ── JWT Authentication ────────────────────────────────────────────────────
JWT_SECRET=           # REQUIRED: Generate with: openssl rand -hex 64
JWT_REFRESH_SECRET=   # REQUIRED: Generate a DIFFERENT secret with: openssl rand -hex 64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Admin panel only (longer sessions than customer app)
ADMIN_JWT_EXPIRES_IN=8h
ADMIN_JWT_REFRESH_EXPIRES_IN=30d

# ── CORS Configuration ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://localhost:19006
# Optional: extra origins appended to CORS_ORIGIN (comma-separated).
CORS_EXTRA_ORIGINS=
CORS_CREDENTIALS=true

# ── Proxy / Cookie Auth ──────────────────────────────────────────────────
# Number of proxy hops to trust for req.ip / rate limiting (Render/CF/Nginx = 1).
TRUST_PROXY=1
# Browser sessions ride in HttpOnly cookies. Defaults ON in production; set
# explicitly when the SPA/API are on different sites.
AUTH_HTTPONLY_COOKIES=
# lax | strict | none. Cross-site cookie auth (e.g. *.vercel.app → *.onrender.com)
# needs 'none' (forces Secure). Same-site should keep 'lax'.
AUTH_COOKIE_SAMESITE=lax
# Share the cookie across subdomains, e.g. ".freshbazar.pk" for admin. + api.
AUTH_COOKIE_DOMAIN=
# Opt-in admin-panel cookie mode (set matching VITE_AUTH_COOKIES=true on the panel).
ADMIN_AUTH_COOKIES=
# Enable the legacy password-only /api/auth/register endpoint (default: disabled).
LEGACY_PASSWORD_REGISTER=false

# ── Sentry Error Tracking (optional) ─────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── Firebase Phone Auth ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Temporary OTP bypass (dev/staging only — set all to false for production Firebase OTP) ──
OTP_BYPASS_ENABLED=false
OTP_BYPASS_CODE=123789

# ── File Upload ──────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ── Redis Cache (optional) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=2000

# ── Server Configuration ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_PREFIX=/api

# ── Admin Panel ──────────────────────────────────────────────────────────
ADMIN_PANEL_PORT=5173
VITE_API_URL=http://localhost:3000/api
# Set true together with backend ADMIN_AUTH_COOKIES=true for HttpOnly-cookie admin auth.
VITE_AUTH_COOKIES=false

# ── Website Firebase Client (NEXT_PUBLIC_) ───────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Temporary fixed OTP — must match backend OTP_BYPASS_ENABLED=true
NEXT_PUBLIC_OTP_BYPASS=false
NEXT_PUBLIC_OTP_BYPASS_CODE=123789

# ── Website ──────────────────────────────────────────────────────────────
WEBSITE_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_NAME=SabziWala
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Temporary fixed OTP — must match backend OTP_BYPASS_ENABLED=true
EXPO_PUBLIC_OTP_BYPASS=false
EXPO_PUBLIC_OTP_BYPASS_CODE=123789

# ── Rider App ────────────────────────────────────────────────────────────
RIDER_APP_PORT=19007
EXPO_PUBLIC_API_URL_RIDER=http://localhost:3000/api

# ── Inbound Webhooks (order-status / payment / sms / rider-location) ──────
# HMAC-SHA256 secret used to verify the X-Webhook-Signature header on every
# inbound webhook (see webhook.controller.ts). If unset in production the API
# fails CLOSED and rejects ALL webhooks, so set this to the same secret you
# configure on the calling provider. Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# ── Payment Gateway (optional) ───────────────────────────────────────────
# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email Service (optional) ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@freshbazar.pk

# ── Google Maps (optional — app uses Expo Go native MapView without this) ─
# Website works without a key (Google embed). Set on Render for smoother JS maps.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Push Notifications (optional) ────────────────────────────────────────
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=

# ============================================================================
# Generating Secure Secrets
# ============================================================================
# For JWT_SECRET and JWT_REFRESH_SECRET, use:
#   openssl rand -hex 64
#
# For production, ensure:
#   - JWT_SECRET and JWT_REFRESH_SECRET are different
#   - Both are at least 64 characters
#   - Stored securely (use a secrets manager in production)
# ============================================================================
