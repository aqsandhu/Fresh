# ============================================================================
# FreshBazar Environment Variables
# Copy this file to .env and fill in all required values
# ============================================================================

# ── Database ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=          # REQUIRED: Set a strong database password
DB_NAME=freshbazar
DB_SSL=false

# ── JWT Authentication ────────────────────────────────────────────────────
JWT_SECRET=           # REQUIRED: Generate with: openssl rand -hex 64
JWT_REFRESH_SECRET=   # REQUIRED: Generate a DIFFERENT secret with: openssl rand -hex 64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS Configuration ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://localhost:19006
CORS_CREDENTIALS=true

# ── Sentry Error Tracking (optional) ─────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── Firebase Phone Auth ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── File Upload ──────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ── Redis Cache (optional) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Server Configuration ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_PREFIX=/api

# ── Admin Panel ──────────────────────────────────────────────────────────
ADMIN_PANEL_PORT=5173
VITE_API_URL=http://localhost:3000/api

# ── Website Firebase Client (NEXT_PUBLIC_) ───────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Website ──────────────────────────────────────────────────────────────
WEBSITE_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_NAME=SabziWala
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# ── Rider App ────────────────────────────────────────────────────────────
RIDER_APP_PORT=19007
EXPO_PUBLIC_API_URL_RIDER=http://localhost:3000/api

# ── Payment Gateway (optional) ───────────────────────────────────────────
# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email Service (optional) ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@freshbazar.pk

# ── Google Maps / Location (optional) ────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Push Notifications (optional) ────────────────────────────────────────
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=

# ============================================================================
# Generating Secure Secrets
# ============================================================================
# For JWT_SECRET and JWT_REFRESH_SECRET, use:
#   openssl rand -hex 64
#
# For production, ensure:
#   - JWT_SECRET and JWT_REFRESH_SECRET are different
#   - Both are at least 64 characters
#   - Stored securely (use a secrets manager in production)
# ============================================================================
