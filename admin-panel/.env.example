# API Configuration
VITE_API_URL=http://localhost:3000/api

# Optional: Set to 'true' to enable debug mode
VITE_DEBUG=false

# HttpOnly-cookie auth (XSS hardening): tokens live in HttpOnly cookies set
# by the backend instead of localStorage. Requires ADMIN_AUTH_COOKIES=true on
# the backend (see backend/.env.production.example for the SameSite/domain
# requirements when panel and API are on different sites).
VITE_AUTH_COOKIES=false
